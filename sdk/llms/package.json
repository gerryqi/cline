{
	"name": "@cline/llms",
	"version": "0.0.0",
	"description": "Config-driven SDK for selecting, extending, and instantiating LLM providers and models",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./sdk": {
			"import": "./dist/sdk.js",
			"types": "./dist/sdk.d.ts"
		},
		"./types": {
			"import": "./dist/types.js",
			"types": "./dist/types.d.ts"
		},
		"./providers": {
			"import": "./dist/providers/index.js",
			"types": "./dist/providers/index.d.ts"
		},
		"./models": {
			"import": "./dist/models/index.js",
			"types": "./dist/models/index.d.ts"
		},
		"./providers/handlers/*": {
			"import": "./dist/providers/handlers/*.js",
			"types": "./dist/providers/handlers/*.d.ts"
		},
		"./models/providers/*": {
			"import": "./dist/models/providers/*.js",
			"types": "./dist/models/providers/*.d.ts"
		},
		"./models/schemas": {
			"import": "./dist/models/schemas/index.js",
			"types": "./dist/models/schemas/index.d.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "bun tsc",
		"typecheck": "bun tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist node_modules",
		"generate:models": "bun run scripts/generate-models.ts"
	},
	"dependencies": {
		"@ai-sdk/amazon-bedrock": "^4.0.67",
		"@aws-sdk/credential-providers": "^3.922.0",
		"@anthropic-ai/sdk": "^0.52.0",
		"@google/genai": "^1.0.0",
		"@streamparser/json": "^0.0.21",
		"ai": "^5.0.0",
		"nanoid": "^5.1.6",
		"openai": "^4.103.0",
		"zod": "^3.23.8"
	},
	"peerDependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.0.0"
	},
	"peerDependenciesMeta": {
		"@aws-sdk/client-bedrock-runtime": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^25.3.0",
		"typescript": "^5.0.0",
		"vitest": "^3.2.4"
	}
}
