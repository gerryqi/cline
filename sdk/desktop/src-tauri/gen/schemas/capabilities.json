{
	"default": {
		"identifier": "default",
		"description": "Default desktop capabilities for Cline",
		"remote": {
			"urls": [
				"http://localhost:3124/*",
				"https://localhost:3124/*",
				"tauri://localhost/*"
			]
		},
		"local": true,
		"windows": ["*"],
		"webviews": ["*"],
		"permissions": [
			"core:default",
			"core:event:default",
			"core:event:allow-listen",
			"core:event:allow-unlisten"
		]
	}
}
