{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default desktop capabilities for Cline",
	"local": true,
	"remote": {
		"urls": [
			"http://localhost:3124/*",
			"https://localhost:3124/*",
			"tauri://localhost/*"
		]
	},
	"windows": ["*"],
	"webviews": ["*"],
	"permissions": [
		"core:default",
		"core:event:default",
		"core:event:allow-listen",
		"core:event:allow-unlisten"
	]
}
