{
	"name": "@clinebot/packages",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*",
		"apps/vscode/src/webview"
	],
	"scripts": {
		"prepare": "husky",
		"build": "bun install && bun run build:sdk && bun -F @clinebot/cli build",
		"build:sdk": "bun -F @clinebot/shared build && bun -F @clinebot/llms build && bun -F @clinebot/scheduler build && bun -F @clinebot/rpc build && bun -F @clinebot/agents build && bun -F @clinebot/core build",
		"build:apps": "bun build:models && bun -F './apps/**' build",
		"build:vscode": "bun -F cline-vscode build",
		"build:models": "bun -F @clinebot/llms generate:models && bun format --write",
		"dev": "bun cli",
		"cli": "bun --conditions=development --cwd apps/cli ./src/index.ts",
		"code": "bun unlink && bun link && bun --conditions=development -F @clinebot/code dev",
		"desktop": "bun --conditions=development -F @clinebot/desktop dev",
		"vscode": "bun --conditions=development -F @clinebot/vscode dev",
		"clean": "bun --parallel -F '*' clean",
		"types": "bun --parallel -F '*' typecheck",
		"test": "bun run test:unit & bun run test:e2e",
		"test:unit": "bun -F @clinebot/agents test & bun -F @clinebot/llms test & bun -F @clinebot/scheduler test & bun -F @clinebot/core test:unit & bun -F @clinebot/cli test:unit",
		"test:e2e": "bun -F @clinebot/core test:e2e & bun -F @clinebot/cli test:e2e",
		"verify:routines": "bun -F @clinebot/scheduler verify:routines",
		"biome": "bunx --bun @biomejs/biome",
		"format": "bun biome format",
		"lint": "bun biome lint",
		"fix": "bun biome check --write --unsafe --diagnostic-level=error"
	},
	"lint-staged": {
		"*": [
			"bun biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"module": "index.ts",
	"type": "module",
	"engines": {
		"bun": ">=1.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "^1.3.10",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@types/node": "^25.3.5"
	}
}
