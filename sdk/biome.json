{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConfusingVoidType": "info",
				"noExplicitAny": "info",
				"noAssignInExpressions": "info",
				"noArrayIndexKey": "info",
				"noUnknownAtRules": {
					"level": "info",
					"options": {
						"ignore": [
							"tailwind",
							"layer",
							"apply",
							"responsive",
							"screen",
							"variants"
						]
					}
				}
			},
			"style": {
				"noNonNullAssertion": "info",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": [
									"@cline/llms/*",
									"@cline/agents/*",
									"@cline/core/*",
									"!@cline/core/server",
									"!@cline/core/server/*"
								],
								"message": "Cross-workspace deep imports are forbidden (except @cline/core/server). Import from package entry points instead."
							}
						]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"json": {
		"formatter": {
			"enabled": true
		}
	}
}
