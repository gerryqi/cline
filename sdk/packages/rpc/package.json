{
	"name": "@cline/rpc",
	"version": "0.0.0",
	"description": "gRPC routing server for clients, sessions, tasks, and tool approvals",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./node": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./browser": {
			"types": "./src/index.browser.ts",
			"import": "./src/index.browser.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "bun run generate:proto && bun run bun.mts && bun tsc --emitDeclarationOnly",
		"clean": "rm -rf dist node_modules",
		"generate:proto": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js -O ./src/proto/generated ./src/proto/rpc.proto",
		"typecheck": "bun tsc --noEmit"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.14.0",
		"@grpc/proto-loader": "^0.8.0",
		"@cline/shared": "workspace:*",
		"better-sqlite3": "^11.10.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"typescript": "^5.7.2"
	}
}
