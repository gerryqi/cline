{
	"name": "@cline/shared",
	"version": "0.0.0",
	"description": "Fast workspace file indexing with rg and fs fallback",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./browser": {
			"types": "./dist/index.browser.d.ts",
			"import": "./dist/index.browser.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "BUILD_MODE=package bun bun.mts",
		"clean": "rm -rf dist node_modules",
		"typecheck": "bun tsc --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/node": "^25.3.3",
		"typescript": "^5.7.2"
	},
	"private": true,
	"dependencies": {
		"jsonrepair": "^3.13.2"
	}
}
